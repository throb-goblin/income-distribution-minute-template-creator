{
  "template": "unit_trust_minute.docx",
  "source": "Unit Trust Minute Template - User Form.docm",
  "branches": ["corporate_multi_director", "corporate_sole_director", "individual_sole_trustee", "individual_multi_trustee"],
  "fields": [
    { "field_path": "trust.name", "placeholders": ["Trust Name", "{{TrustName}}"], "usage": "minute body" },
    { "field_path": "distribution.income_year", "placeholders": ["YEAR"], "usage": "minute body" },
    { "field_path": "distribution.resolution_date", "placeholders": ["______________________"], "usage": "minute body" },
    { "field_path": "trust.deed_date", "placeholders": ["Est Date", "{{EstDate}}"], "usage": "recitals" },
    { "field_path": "trustee.name", "placeholders": ["Trustee 1", "{{Trustee1}}"], "usage": "recitals and execution" },
    { "field_path": "trustee.acn", "placeholders": ["XXX XXX XXX", "{{TrusteeACN}}"], "usage": "recitals" },
    { "field_path": "trust.initial_unitholder.name", "placeholders": ["InitialUnitholder 1", "{{InitialUnitholder1}}"], "usage": "recitals" },
    { "field_path": "trust.vesting.date", "placeholders": ["V Date", "{{VDate}}"], "usage": "vesting recital" },
    { "field_path": "trust.vesting.clause_ref", "placeholders": ["clause 1.29"], "usage": "clause reference" },
    { "field_path": "income.definition_clause_ref", "placeholders": ["clause 1.24.2", "clause 1.25.2"], "usage": "clause reference" },
    { "field_path": "income.distribution_power_clause_ref", "placeholders": ["clause 5.1.3"], "usage": "clause reference" },
    { "field_path": "income.streaming_clause_ref", "placeholders": ["clause 5.2.4"], "usage": "clause reference" },
    { "field_path": "income.accumulation_clause_ref", "placeholders": [], "usage": "clause reference" },
    { "field_path": "capital.determination_clause_ref", "placeholders": [], "usage": "clause reference" },
    { "field_path": "unitholders.register_clause_ref", "placeholders": ["clause 1.26"], "usage": "clause reference" },
    { "field_path": "unitholders.holdings", "placeholders": [], "usage": "eligible parties" },
    { "field_path": "distribution.items", "placeholders": ["INDIVIDUAL A", "INDIVIDUAL B"], "usage": "repeatable distribution data" },
    { "field_path": "distribution.method", "placeholders": [], "usage": "method wording" },
    { "field_path": "distribution.method_clause_ref", "placeholders": [], "usage": "clause reference" },
    { "field_path": "distribution.resolution_deadline_clause_ref", "placeholders": [], "usage": "clause reference" },
    { "field_path": "trustee.directors", "placeholders": ["Director 1", "Director 2", "Director 3", "Director 4", "Director 5", "Director 6", "{{Director1}}", "{{Director2}}", "{{Director3}}", "{{Director4}}", "{{Director5}}", "{{Director6}}"], "usage": "execution" },
    { "field_path": "trustee.individual_trustees", "placeholders": ["Trustee 2", "Trustee 3", "Trustee 4", "Trustee 5", "Trustee 6", "{{Trustee2}}", "{{Trustee3}}", "{{Trustee4}}", "{{Trustee5}}", "{{Trustee6}}"], "usage": "execution" }
  ],
  "linked_clause_fields": [
    "trust.vesting.clause_ref",
    "income.definition_clause_ref",
    "income.distribution_power_clause_ref",
    "income.streaming_clause_ref",
    "income.accumulation_clause_ref",
    "capital.determination_clause_ref",
    "unitholders.register_clause_ref",
    "distribution.method_clause_ref",
    "distribution.resolution_deadline_clause_ref"
  ],
  "placeholder_policy": {
    "mapped": [
      "Trust Name",
      "{{TrustName}}",
      "Trustee 1",
      "Trustee 2",
