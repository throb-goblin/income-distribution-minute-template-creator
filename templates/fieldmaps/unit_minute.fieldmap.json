      "XXX XXX XXX",
      "{{TrusteeACN}}",
      "InitialUnitholder 1",
      "{{InitialUnitholder1}}",
      "Est Date",
      "{{EstDate}}",
      "V Date",
      "{{VDate}}",
      "{{VestingDate}}",
      "YEAR",
      "Director 1",
      "Director 2",
      "Director 3",
      "Director 4",
      "Director 5",
      "Director 6",
      "{{Director1}}",
      "{{Director2}}",
      "{{Director3}}",
      "{{Director4}}",
      "{{Director5}}",
      "{{Director6}}",
      "{{Comma1}}",
      "{{Comma2}}",
      "{{Comma3}}",
      "{{Comma4}}",
      "{{Comma5}}",
      "INDIVIDUAL A",
      "INDIVIDUAL B",
      "{{NetIncome}}",
      "{{Unitholders}}",
      "{{Capital}}"
    ],
    "deliberately_removed": ["comma1", "comma2", "comma3", "comma4", "comma5", "comma6"],
    "deliberately_retained": ["Beneficiaries", "Unitholder", "Unitholders", "Net Income", "Distributable Income", "Capital"]
  }
}
