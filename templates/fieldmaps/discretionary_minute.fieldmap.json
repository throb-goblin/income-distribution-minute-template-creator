{
  "template": "discretionary_trust_minute.docx",
  "source": "Discretionary Trust Minute Template - User Form.docm",
  "branches": ["corporate_multi_director", "corporate_sole_director", "individual_sole_trustee", "individual_multi_trustee"],
  "fields": [
    { "field_path": "trust.name", "placeholders": ["Trust Name"], "usage": "minute body" },
    { "field_path": "distribution.income_year", "placeholders": ["YEAR"], "usage": "minute body" },
    { "field_path": "distribution.resolution_date", "placeholders": ["______________________"], "usage": "minute body" },
    { "field_path": "trust.deed_date", "placeholders": ["Est Date"], "usage": "recitals" },
    { "field_path": "trustee.name", "placeholders": ["Trustee 1"], "usage": "recitals and execution" },
    { "field_path": "trustee.acn", "placeholders": ["XXX XXX XXX"], "usage": "recitals" },
    { "field_path": "trust.settlor.name", "placeholders": ["Settlor 1"], "usage": "recitals" },
    { "field_path": "trust.vesting.date", "placeholders": ["V Date"], "usage": "vesting recital" },
    { "field_path": "trust.vesting.clause_ref", "placeholders": ["clause 1.33"], "usage": "clause reference" },
    { "field_path": "income.definition_clause_ref", "placeholders": ["clause 1.12"], "usage": "clause reference" },
    { "field_path": "income.distribution_power_clause_ref", "placeholders": ["Clause 9"], "usage": "clause reference" },
    { "field_path": "income.streaming_clause_ref", "placeholders": ["clause 11.5"], "usage": "clause reference" },
    { "field_path": "income.accumulation_clause_ref", "placeholders": [], "usage": "clause reference" },
    { "field_path": "capital.determination_clause_ref", "placeholders": [], "usage": "clause reference" },
    { "field_path": "beneficiaries.definition_clause_ref", "placeholders": ["clause 1.4"], "usage": "clause reference" },
    { "field_path": "beneficiaries.classes", "placeholders": [], "usage": "eligible parties" },
    { "field_path": "distribution.items", "placeholders": ["INDIVIDUAL A", "INDIVIDUAL B", "COMPANY A Pty Ltd", "TRUSTEE A, in their capacity as trustee for the TRUST A"], "usage": "repeatable distribution data" },
    { "field_path": "distribution.method", "placeholders": [], "usage": "method wording" },
    { "field_path": "distribution.method_clause_ref", "placeholders": [], "usage": "clause reference" },
    { "field_path": "distribution.resolution_deadline_clause_ref", "placeholders": [], "usage": "clause reference" },
    { "field_path": "trustee.directors", "placeholders": ["Director 1", "Director 2", "Director 3", "Director 4", "Director 5", "Director 6"], "usage": "execution" },
    { "field_path": "trustee.individual_trustees", "placeholders": ["Trustee 2", "Trustee 3", "Trustee 4", "Trustee 5", "Trustee 6"], "usage": "execution" }
  ],
  "linked_clause_fields": [
    "trust.vesting.clause_ref",
    "income.definition_clause_ref",
    "income.distribution_power_clause_ref",
    "income.streaming_clause_ref",
    "income.accumulation_clause_ref",
    "capital.determination_clause_ref",
    "beneficiaries.definition_clause_ref",
    "distribution.method_clause_ref",
    "distribution.resolution_deadline_clause_ref"
  ],
  "placeholder_policy": {
    "mapped": [
      "Trust Name",
      "Trustee 1",
      "Trustee 2",
      "Trustee 3",
      "Trustee 4",
      "Trustee 5",
      "Trustee 6",
      "XXX XXX XXX",
      "Settlor 1",
      "Est Date",
      "V Date",
      "YEAR",
      "Director 1",
      "Director 2",
      "Director 3",
      "Director 4",
      "Director 5",
      "Director 6",
      "INDIVIDUAL A",
      "INDIVIDUAL B",
      "COMPANY A Pty Ltd",
      "TRUSTEE A, in their capacity as trustee for the TRUST A"
    ],
    "deliberately_removed": ["comma1", "comma2", "comma3", "comma4", "comma5", "comma6"],
    "deliberately_retained": ["Beneficiaries", "Distributable Income", "Capital"]
  }
}
